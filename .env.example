# =============================================================================
# .env.example — copy this to .env and fill in real values
# NEVER commit .env to the repo
# =============================================================================

# API credentials for skills that call external services
TEST_API_KEY=your-api-key-here
TEST_API_SECRET=your-api-secret-here

# Database credentials for skills that query data
TEST_DB_HOST=your-db-host-here
TEST_DB_PASSWORD=your-db-password-here

# PII test data (for real-data evals, kept out of repo)
TEST_REAL_FIXTURES_PATH=C:/path/to/your/real/fixtures

# Identity fields used in real-data evals
TEST_EMPLOYER_ID=your-employer-id-here
TEST_EMPLOYEE_SSN=your-ssn-here
TEST_EMPLOYEE_DOB=your-dob-here

# Anthropic API key for running evals against Claude
ANTHROPIC_API_KEY=your-anthropic-key-here
